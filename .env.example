# Copy to .env on the host PC. Never commit the real file.

# Anthropic / Claude API (used in Weekend 2)
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# Backend
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/mindmap.db
# Comma-separated list of allowed origins for CORS in dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (used at build time)
VITE_API_BASE_URL=/api

# Whisper (used in Weekend 3)
# RTX 4070 Super 12GB comfortably runs large-v3 in fp16.
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
